<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate x:Key="BoldHeaderTemplate">
        <TextBlock Text="{Binding}"
               FontWeight="Bold"/>
    </DataTemplate>

    <Style x:Key="BoldTextBoxHeaderStyle" TargetType="TextBox">
        <Setter Property="HeaderTemplate" Value="{StaticResource BoldHeaderTemplate}"/>
    </Style>

    <Style x:Key="BoldPasswordBoxHeaderStyle" TargetType="PasswordBox">
        <Setter Property="HeaderTemplate" Value="{StaticResource BoldHeaderTemplate}"/>
    </Style>

</ResourceDictionary>