<Page
    x:Class="piaWinUI.Views.ReporteProductosPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="20">
            <Button Content="← Volver" Click="Volver_Click"/>
            <TextBlock Text="Reporte de Productos" FontSize="28" FontWeight="Bold"/>

            <Button Content="Exportar a PDF" Click="ExportarPDF_Click" Margin="0,10,0,0"/>

            <Border Background="#2C2C2C" Padding="15" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="Productos por categoría" Foreground="White" FontWeight="Bold"/>
                    <lvc:PieChart Series="{Binding CategoriaSeries}" Height="300"/>
                </StackPanel>
            </Border>

            <Border Background="#2C2C2C" Padding="15" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="Stock por producto" Foreground="White" FontWeight="Bold"/>
                    <lvc:CartesianChart Series="{Binding StockSeries}" XAxes="{Binding XAxes}" YAxes="{Binding YAxes}" Height="300"/>
                </StackPanel>
            </Border>

            <Border Background="#43A047" Padding="15" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Valor total inventario" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="InventarioText" Foreground="White" FontSize="24" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>