<Page
    x:Class="piaWinUI.Views.ReporteProductosPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="20">

            <Button Content="← Volver" Click="Volver_Click"/>

            <TextBlock Text="Reporte de Productos" FontSize="28"/>

            <Button Content="Exportar a PDF"
                    Click="ExportarPDF_Click"
                    Margin="10,0,0,0"/>

            <!-- CATEGORIAS -->
            <Border Background="#2C2C2C" Padding="15" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="Productos por categoría" Foreground="White"/>
                    <TextBlock Text="Distribución del inventario" Foreground="LightGray"/>

                    <lvc:PieChart Series="{Binding CategoriaSeries}" Height="250"/>
                </StackPanel>
            </Border>

            <!-- STOCK -->
            <Border Background="#2C2C2C" Padding="15" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="Stock por producto" Foreground="White"/>
                    <TextBlock Text="Cantidad disponible" Foreground="LightGray"/>

                    <lvc:CartesianChart 
                        Series="{Binding StockSeries}"
                        XAxes="{Binding XAxes}"
                        Height="250"/>
                </StackPanel>
            </Border>

            <!-- KPI -->
            <Border Background="#43A047" Padding="12" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Valor total inventario" Foreground="White"/>
                    <TextBlock x:Name="InventarioText" Foreground="White"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>