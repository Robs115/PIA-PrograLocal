<Page
    x:Class="piaWinUI.Views.ReporteClientesPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="20">

            <Button Content="← Volver" Click="Volver_Click"/>

            <TextBlock Text="Reporte de Clientes" FontSize="28"/>

            <!-- EDADES -->
            <Border Background="#2C2C2C" CornerRadius="12" Padding="15">
                <StackPanel>
                    <TextBlock Text="Distribución por edad" Foreground="White"/>
                    <TextBlock Text="Clientes por rango de edad" Foreground="LightGray"/>

                    <lvc:PieChart Series="{Binding EdadSeries}" Height="250"/>
                </StackPanel>
            </Border>

            <!-- CLIENTES POR AÑO -->
            <Border Background="#2C2C2C" CornerRadius="12" Padding="15">
                <StackPanel>
                    <TextBlock Text="Clientes por año" Foreground="White"/>
                    <TextBlock Text="Año de nacimiento agrupado" Foreground="LightGray"/>

                    <lvc:CartesianChart 
                        Series="{Binding ClientesAnioSeries}"
                        XAxes="{Binding XAxes}"
                        Height="250"/>
                </StackPanel>
            </Border>

            <!-- KPIs -->
            <Border Background="#1E88E5" Padding="12" CornerRadius="10">
                <StackPanel>
                    <TextBlock Text="Edad promedio" Foreground="White"/>
                    <TextBlock x:Name="PromedioEdadText" Foreground="White"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>