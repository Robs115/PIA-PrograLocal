<Page
    x:Class="piaWinUI.Reportes"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="20">
            <TextBlock Text="Dashboard de Reportes" FontSize="28" FontWeight="Bold"/>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Productos" Click="GoProductosReport" Style="{StaticResource AccentButtonStyle}"/>
                <Button Content="Ventas" Click="GoVentasReport" Style="{StaticResource AccentButtonStyle}"/>
                <Button Content="Exportar a PDF" Click="ExportarPDF_Click" Margin="20,0,0,0"/>
            </StackPanel>

            <Grid ColumnDefinitions="*,*,*">
                <Border Background="#1E88E5" CornerRadius="10" Padding="15" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Total ventas" Foreground="White" FontSize="12"/>
                        <TextBlock x:Name="TotalVentasText" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#43A047" CornerRadius="10" Padding="15" Margin="5" Grid.Column="1">
                    <StackPanel>
                        <TextBlock Text="Ingresos totales" Foreground="White" FontSize="12"/>
                        <TextBlock x:Name="IngresosText" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#F4511E" CornerRadius="10" Padding="15" Margin="5" Grid.Column="2">
                    <StackPanel>
                        <TextBlock Text="Productos vendidos" Foreground="White" FontSize="12"/>
                        <TextBlock x:Name="ProdVendidosText" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="15" CornerRadius="12" Background="#2C2C2C">
                <lvc:CartesianChart Series="{Binding TendenciaSeries}" XAxes="{Binding TendenciaXAxes}" YAxes="{Binding TendenciaYAxes}" Height="300"/>
            </Border>

            <Border Padding="15" CornerRadius="12" Background="#2C2C2C">
                <lvc:PieChart Series="{Binding ProductosSeries}" Height="300" LegendPosition="Bottom"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>