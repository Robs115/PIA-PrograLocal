<Page
    x:Class="piaWinUI.Reportes"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="20">

            <!-- TÍTULO -->
            <TextBlock Text="Dashboard de Reportes"
                       FontSize="28"
                       FontWeight="Bold"/>

            <!-- KPIs -->
            <Grid ColumnDefinitions="*,*,*">

                <Border Background="#1E88E5" CornerRadius="10" Padding="15" Margin="5">
                    <TextBlock Text="$5,230" FontSize="22" Foreground="White"/>
                </Border>

                <Border Background="#43A047" CornerRadius="10" Padding="15" Margin="5">
                    <TextBlock Text="$8,120" FontSize="22" Foreground="White"/>
                </Border>

                <Border Background="#E53935" CornerRadius="10" Padding="15" Margin="5">
                    <TextBlock Text="$2,890" FontSize="22" Foreground="White"/>
                </Border>

            </Grid>

            <!-- 📊 BARRAS -->
            <Border Padding="15" CornerRadius="12" Background="#2C2C2C">
                <StackPanel Spacing="8">

                    <TextBlock Text="Ventas por día"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="White"/>

                    <TextBlock Text="Representa el total de ventas registradas en los últimos días"
                   FontSize="12"
                   Foreground="LightGray"/>

                    <lvc:CartesianChart 
            Series="{Binding VentasSeries}" 
            Height="250"/>

                </StackPanel>
            </Border>

            <!-- 📈 LÍNEA -->
            <Border Padding="15" CornerRadius="12" Background="#2C2C2C">
                <StackPanel Spacing="8">

                    <TextBlock Text="Tendencia de ingresos"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="White"/>

                    <TextBlock Text="Muestra el comportamiento de ingresos a lo largo del tiempo"
                   FontSize="12"
                   Foreground="LightGray"/>

                    <lvc:CartesianChart 
            Series="{Binding TendenciaSeries}" 
            Height="250"/>

                </StackPanel>
            </Border>

            <!-- 🥧 PASTEL -->
            <Border Padding="15" CornerRadius="12" Background="#2C2C2C">
                <StackPanel Spacing="8">

                    <TextBlock Text="Distribución de productos"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="White"/>

                    <TextBlock Text="Porcentaje de ventas por tipo de producto"
                   FontSize="12"
                   Foreground="LightGray"/>

                    <lvc:PieChart 
            Series="{Binding ProductosSeries}" 
            Height="250"
                        LegendPosition="Bottom"/>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>