<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="piaWinUI.Views.BuscarProveedoresPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:piaWinUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid >
        <ScrollViewer VerticalScrollBarVisibility ="Auto">
            <StackPanel HorizontalAlignment ="Center" VerticalAlignment ="Center" 
Spacing ="30">


                <StackPanel HorizontalAlignment ="Center" Margin ="0,0,0,12" Spacing ="8">
                    <SymbolIcon Symbol ="Find" />
                    <TextBlock Text ="Buscar Proveedor"  
               Style ="{StaticResource TitleTextBlockStyle }" 
               HorizontalAlignment ="Center" />




                </StackPanel >

                <TextBox x:Name="buscador" 
                     Header ="Nombre del Proveedor *" 
                     PlaceholderText ="Ej. Nelson Orlando Rodriguez"
                         TextChanged="Buscador_TextChanged"/>

                <Grid ColumnSpacing="10" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Nombre" FontWeight="Bold" Grid.Column="0"/>
                    <TextBlock Text="Teléfono" FontWeight="Bold" Grid.Column="1"/>
                    <TextBlock Text="Email" FontWeight="Bold" Grid.Column="2"/>
                    <TextBlock Text="Acciones" FontWeight="Bold" Grid.Column="3"/>
                </Grid>


                <ListView x:Name="ProveedoresList"
          Height="300">

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Nombre}" Grid.Column="0"/>
                                <TextBlock Text="{Binding Telefono}" Grid.Column="1"/>
                                <TextBlock Text="{Binding Email}" Grid.Column="2"/>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="5">
                                    <Button Content="Editar" Click="EditarProveedor_Click" Style="{StaticResource AccentButtonStyle}" Tag="{Binding IdProveedor}"/>
                                    <Button Content="Eliminar" Click="Eliminar_Click" Style="{StaticResource AccentButtonStyle}" Tag="{Binding IdProveedor}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>











                <TextBlock x:Name="StatusTextBlock"></TextBlock >



                <Button x:Name="Submit"  
                            Content ="Regresar"  
                          Click="regresar_click"
                            Style ="{ StaticResource AccentButtonStyle }"  
                            HorizontalAlignment ="Stretch" />



            </StackPanel >
        </ScrollViewer >
        <ContentDialog x:Name="EditarProveedorDialog"
       Title="Editar proveedor"
       PrimaryButtonText="Editar"
       CloseButtonText="Cancelar">

            <StackPanel Spacing="10">

                <TextBox x:Name="nombreeditar"
         Header="Nombre"/>

                <TextBox x:Name="telefonoeditar"
         Header="Teléfono"/>

                <TextBox x:Name="emaileditar"
         Header="Email"/>

            </StackPanel>
        </ContentDialog>
    </Grid >
</Page>
