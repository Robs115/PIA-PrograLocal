<Page
    x:Class="piaWinUI.PedidosPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">
    

    <Grid Padding="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- FORMULARIO -->
        <Border Background="#2C2C2C" CornerRadius="12" Padding="20">

            <StackPanel Spacing="15">

                <TextBlock Text="Nuevo Pedido"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"/>

                <StackPanel>
                    <TextBlock Text="Producto" Foreground="LightGray"/>
                    <ComboBox x:Name="cmbProducto"
                              DisplayMemberPath="Nombre"
                              SelectionChanged="cmbProducto_SelectionChanged"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Proveedor" Foreground="LightGray"/>
                    <ComboBox x:Name="cmbProveedor"
                              DisplayMemberPath="Nombre"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Cantidad" Foreground="LightGray"/>
                    <TextBox x:Name="txtCantidad"/>
                </StackPanel>

                <Button Content="Registrar Pedido"
                        Click="RegistrarPedido_Click"
                        Background="#8B1E2D"
                        Foreground="White"
                        Height="40"/>

            </StackPanel>
        </Border>

        <!-- TABLA -->
        <StackPanel Grid.Column="1" Margin="20,0,0,0" Spacing="10">

            <TextBlock Text="Historial de Pedidos"
                       FontSize="22"
                       FontWeight="Bold"/>

            <TextBox x:Name="txtBuscar"
                     PlaceholderText="Buscar..."
                     TextChanged="Buscar_TextChanged"/>

            <controls:DataGrid x:Name="gridPedidos" AutoGenerateColumns="False">
                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Producto" Binding="{Binding Producto}"/>
                    <controls:DataGridTextColumn Header="Proveedor" Binding="{Binding Proveedor}"/>
                    <controls:DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}"/>
                    <controls:DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}"/>
                </controls:DataGrid.Columns>
            </controls:DataGrid>

        </StackPanel>

    </Grid>
</Page>