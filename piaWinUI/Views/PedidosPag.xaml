<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="piaWinUI.Views.PedidosPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#181818">

    <Grid Padding="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 🔥 PANEL IZQUIERDO -->
        <Border Grid.Column="0"
                Background="#1F1F1F"
                CornerRadius="20"
                Padding="24"
                BorderBrush="#2B2B2B"
                BorderThickness="1">

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">

                <StackPanel Spacing="16">

                    <!-- TITULO -->
                    <TextBlock Text="Nuevo Pedido"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,0,0,10"/>

                    <!-- PRODUCTO -->
                    <TextBlock Text="Producto"
                               Foreground="#D0D0D0"
                               FontSize="14"/>

                    <ComboBox x:Name="cmbProductoPedido"
                              PlaceholderText="Seleccionar producto"
                              Height="46"
                              Background="#292929"
                              BorderBrush="#3A3A3A"
                              Foreground="White"
                              CornerRadius="10"
                              SelectionChanged="cmbProductoPedido_SelectionChanged"/>

                    <!-- PROVEEDOR -->
                    <TextBlock Text="Proveedor"
                               Foreground="#D0D0D0"
                               FontSize="14"/>

                    <ComboBox x:Name="cmbProveedorPedido"
                              PlaceholderText="Seleccionar proveedor"
                              Height="46"
                              Background="#292929"
                              BorderBrush="#3A3A3A"
                              Foreground="White"
                              CornerRadius="10"
                              SelectionChanged="cmbProveedorPedido_SelectionChanged"/>

                    <!-- CANTIDAD -->
                    <TextBlock Text="Cantidad"
                               Foreground="#D0D0D0"
                               FontSize="14"/>

                    <TextBox x:Name="txtCantidadPedido"
                             PlaceholderText="Ej. 10"
                             Height="46"
                             Padding="12,0,12,3"
                             VerticalContentAlignment="Center"
                             Background="#292929"
                             BorderBrush="#3A3A3A"
                             Foreground="White"
                             CornerRadius="10"
                             MaxLength="10"
                             TextChanged="txtCantidadPedido_TextChanged"/>      

                    <!-- BOTON -->
                    <Button Content="Registrar Pedido"
                            Height="48"
                            Margin="0,18,0,0"
                            Click="RegistrarPedido_Click"
                            Background="#A61D4C"
                            Foreground="White"
                            FontWeight="SemiBold"
                            CornerRadius="12"
                            BorderThickness="0"/>

                </StackPanel>

            </ScrollViewer>

        </Border>

        <!-- 🔥 PANEL DERECHO -->
        <StackPanel Grid.Column="2"
                    Spacing="14">

            <!-- TITULO -->
            <TextBlock Text="Historial de Pedidos"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="5,0,0,0"/>

            <!-- BUSCADOR -->
            <TextBox x:Name="txtBuscar"
                     PlaceholderText="Buscar pedido..."
                     Height="46"
                     CornerRadius="10"
                     Padding="12,0,12,3"
                     VerticalContentAlignment="Center"
                     Background="#252525"
                     BorderBrush="#3A3A3A"
                     Foreground="White"
                     TextChanged="txtBuscar_TextChanged"/>

            <!-- 🔥 TABLA -->
            <Border Background="#1F1F1F"
                    CornerRadius="18"
                    BorderBrush="#2C2C2C"
                    BorderThickness="1"
                    Padding="0">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="65"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 🔥 HEADER -->
                    <Border Grid.Row="0"
                            Background="#2B2B2B"
                            CornerRadius="18,18,0,0">

                        <Grid Padding="22,0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <!-- PRODUCTO -->
                            <TextBlock Text="Producto"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="#F5F5F5"
                                       FontSize="15"/>

                            <!-- PROVEEDOR -->
                            <TextBlock Text="Proveedor"
                                       Grid.Column="1"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="#F5F5F5"
                                       FontSize="15"/>

                            <!-- CANTIDAD -->
                            <TextBlock Text="Cantidad"
                                       Grid.Column="2"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Foreground="#F5F5F5"
                                       FontSize="15"/>

                            <!-- FECHA -->
                            <TextBlock Text="Fecha"
                                       Grid.Column="3"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="#F5F5F5"
                                       FontSize="15"/>
                        </Grid>
                    </Border>

                    <!-- 🔥 LISTA -->
                    <ListView x:Name="gridPedidos"
                              Grid.Row="1"
                              Background="Transparent"
                              BorderThickness="0"
                              SelectionMode="Single"
                              Padding="5">

                        <!-- ITEMS -->
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">

                                <Setter Property="HorizontalContentAlignment"
                                        Value="Stretch"/>

                                <Setter Property="Padding"
                                        Value="0"/>

                                <Setter Property="Margin"
                                        Value="0,0,0,2"/>

                                <Setter Property="MinHeight"
                                        Value="55"/>

                                <Setter Property="Background"
                                        Value="Transparent"/>

                            </Style>
                        </ListView.ItemContainerStyle>

                        <!-- TEMPLATE -->
                        <ListView.ItemTemplate>
                            <DataTemplate>

                                <Border Background="#242424"
                                        CornerRadius="12"
                                        Margin="8,6"
                                        Padding="18,14"
                                        BorderBrush="#303030"
                                        BorderThickness="1">

                                    <Grid>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- PRODUCTO -->
                                        <TextBlock Text="{Binding NombreProducto}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- PROVEEDOR -->
                                        <TextBlock Text="{Binding NombreProveedor}"
                                                   Grid.Column="1"
                                                   Foreground="#D6D6D6"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- CANTIDAD -->
                                        <Border Grid.Column="2"
                                                Background="#A61D4C"
                                                CornerRadius="8"
                                                Padding="10,4"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">

                                            <TextBlock Text="{Binding Cantidad}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center"/>
                                        </Border>

                                        <!-- FECHA -->
                                        <TextBlock Text="{Binding FechaFormateada}"
                                                   Grid.Column="3"
                                                   Foreground="#BDBDBD"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>

                                    </Grid>

                                </Border>

                            </DataTemplate>
                        </ListView.ItemTemplate>

                    </ListView>

                </Grid>

            </Border>

        </StackPanel>

    </Grid>
</Page>