<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="piaWinUI.Views.PedidosPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 🔥 PANEL IZQUIERDO -->
        <Border Grid.Column="0"
                Background="#1E1E1E"
                CornerRadius="12"
                Padding="20">

            <StackPanel Spacing="15">

                <TextBlock Text="Nuevo Pedido"
                           FontSize="20"
                           FontWeight="Bold"/>

                <!-- PRODUCTO -->
                <TextBlock Text="Producto"/>
                <ComboBox x:Name="cmbProductoPedido"
                          PlaceholderText="Seleccionar producto"
                          SelectionChanged="cmbProductoPedido_SelectionChanged"/>

                <!-- PROVEEDOR -->
                <TextBlock Text="Proveedor"/>
                <ComboBox x:Name="cmbProveedorPedido"
                          PlaceholderText="Seleccionar proveedor"/>

                <!-- CANTIDAD -->
                <TextBlock Text="Cantidad"/>
                <TextBox x:Name="txtCantidadPedido"
                         PlaceholderText="Ej. 10"/>

                <!-- BOTON -->
                <Button Content="Registrar Pedido"
                        Click="RegistrarPedido_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        Margin="0,10,0,0"/>

            </StackPanel>
        </Border>

        <!-- 🔥 PANEL DERECHO -->
        <StackPanel Grid.Column="1" Margin="20,0,0,0" Spacing="10">

            <TextBlock Text="Historial de Pedidos"
                       FontSize="22"
                       FontWeight="Bold"/>

            <!-- BUSCADOR -->
            <TextBox x:Name="txtBuscarPedido"
                     PlaceholderText="Buscar..."
                     TextChanged="BuscarPedido_TextChanged"/>

            <!-- HEADER -->
            <Grid Background="#111" Padding="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Producto" FontWeight="Bold"/>
                <TextBlock Text="Proveedor" Grid.Column="1" FontWeight="Bold"/>
                <TextBlock Text="Cantidad" Grid.Column="2" FontWeight="Bold"/>
                <TextBlock Text="Fecha" Grid.Column="3" FontWeight="Bold"/>
            </Grid>

            <!-- LISTA -->
            <ListView x:Name="gridPedidos"
                      Background="Transparent"
                      BorderThickness="0">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding NombreProducto}" />
                            <TextBlock Text="{Binding NombreProveedor}" Grid.Column="1"/>
                            <TextBlock Text="{Binding Cantidad}" Grid.Column="2"/>
                            <TextBlock Text="{Binding Fecha}" Grid.Column="3"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>

        </StackPanel>

    </Grid>
</Page>