<?xml version="1.0" encoding="utf-8"?>

<Page
    x:Class="piaWinUI.Views.PedidosPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d"
    Background="#0F172A">

    <Grid Padding="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 🔥 PANEL IZQUIERDO -->
        <Border Grid.Column="0"
            Background="#111827"
            CornerRadius="12"
            Padding="20"
            BorderBrush="#334155"
            BorderThickness="1">

            <StackPanel Spacing="15">

                <!-- ICONO -->
                <SymbolIcon Symbol="Shop"
                    HorizontalAlignment="Center"
                    Foreground="#60A5FA"/>

                <!-- TITULO -->
                <TextBlock Text="Nuevo Pedido"
                   Style="{StaticResource TitleTextBlockStyle}"
                   HorizontalAlignment="Center"
                   Foreground="#E2E8F0"/>

                <!-- SUBTITULO -->
                <TextBlock Text="Introduce los datos"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="#94A3B8"
                   HorizontalAlignment="Center"/>

                <!-- PRODUCTO -->
                <ComboBox x:Name="cmbProductoPedido"
                  Header="Producto *"
                  PlaceholderText="Seleccionar producto"
                  SelectionChanged="cmbProductoPedido_SelectionChanged"
                  Background="#0F172A"
                  Foreground="#F8FAFC"
                  BorderBrush="#334155"/>

                <!-- PROVEEDOR -->
                <ComboBox x:Name="cmbProveedorPedido"
                  Header="Proveedor *"
                  PlaceholderText="Seleccionar proveedor"
                  SelectionChanged="cmbProveedorPedido_SelectionChanged"
                  Background="#0F172A"
                  Foreground="#F8FAFC"
                  BorderBrush="#334155"/>

                <!-- CANTIDAD -->
                <TextBox x:Name="txtCantidadPedido"
                 Header="Cantidad *"
                 PlaceholderText="Ej. 10"
                 MaxLength="10"
                 TextChanged="txtCantidadPedido_TextChanged"
                 Background="#0F172A"
                 Foreground="#F8FAFC"
                 BorderBrush="#334155"/>

                <!-- BOTÓN -->
                <Button Content="Registrar Pedido"
                Click="RegistrarPedido_Click"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Stretch"
                Margin="0,10,0,0"
                Background="#2563EB"
                Foreground="White"/>

            </StackPanel>

        </Border>

        <!-- 🔥 PANEL DERECHO -->
        <StackPanel Grid.Column="1"
                    Margin="20,0,0,0"
                    Spacing="10">

            <!-- TITULO -->
            <TextBlock Text="Historial de Pedidos"
                       Style="{StaticResource TitleTextBlockStyle}"
                       HorizontalAlignment="Center"/>

            <!-- BUSCADOR -->
            <TextBox x:Name="txtBuscar"
                     PlaceholderText="Buscar..."
                     MaxLength="45"
                     TextChanged="txtBuscar_TextChanged"/>

            <!-- 🔥 TABLA -->
            <controls:DataGrid
                x:Name="gridPedidos"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                GridLinesVisibility="Vertical"
                HeadersVisibility="Column"
                CanUserResizeColumns="False"
                CanUserReorderColumns="False"
                Margin="10"
                SelectionMode="Single"
                RowHeight="50">

                <controls:DataGrid.Columns>

                    <!-- PRODUCTO -->
                    <controls:DataGridTemplateColumn
                        Header="          Producto"
                        Width="2*">

                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <TextBlock Text="{Binding NombreProducto}"
                                           TextDecorations="Underline"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                            </DataTemplate>

                        </controls:DataGridTemplateColumn.CellTemplate>

                    </controls:DataGridTemplateColumn>

                    <!-- PROVEEDOR -->
                    <controls:DataGridTemplateColumn
                        Header="         Proveedor"
                        Width="2*">

                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <TextBlock Text="{Binding NombreProveedor}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                            </DataTemplate>

                        </controls:DataGridTemplateColumn.CellTemplate>

                    </controls:DataGridTemplateColumn>

                    <!-- CANTIDAD -->
                    <controls:DataGridTemplateColumn
                        Header="   Cantidad"
                        Width="1.2*">

                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <TextBlock Text="{Binding Cantidad}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>

                            </DataTemplate>

                        </controls:DataGridTemplateColumn.CellTemplate>

                    </controls:DataGridTemplateColumn>

                    <!-- FECHA -->
                    <controls:DataGridTemplateColumn
                        Header="            Fecha"
                        Width="2*">

                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <TextBlock Text="{Binding FechaFormateada}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                            </DataTemplate>

                        </controls:DataGridTemplateColumn.CellTemplate>

                    </controls:DataGridTemplateColumn>

                </controls:DataGrid.Columns>

            </controls:DataGrid>

        </StackPanel>

    </Grid>

</Page>