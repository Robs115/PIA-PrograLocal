<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="piaWinUI.Views.ClientesPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:piaWinUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    
       <Grid >
            <ScrollViewer VerticalScrollBarVisibility ="Auto">
                <StackPanel HorizontalAlignment ="Center" VerticalAlignment ="Center" 
Spacing ="14">


                    <StackPanel HorizontalAlignment ="Center" Margin ="0,0,0,12" Spacing ="8">
                        <SymbolIcon Symbol ="AddFriend" />
                        <TextBlock Text ="Crear cliente"  
               Style ="{StaticResource TitleTextBlockStyle }" 
               HorizontalAlignment ="Center" />
                        <TextBlock Text ="Introduce los datos"  
               Style ="{StaticResource CaptionTextBlockStyle }"  
               Foreground ="{ThemeResource TextFillColorSecondaryBrush }" 
               HorizontalAlignment ="Center" />
                    <Grid ColumnSpacing ="10">
                        <Grid.ColumnDefinitions >
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions >
                        <Button Grid.Column="0" x:Name="reportesClientes"  
            Content ="Reportes de clientes"  
            Click="ReporteClientes_Click"
            Style ="{ StaticResource AccentButtonStyle }"  
            HorizontalAlignment ="Stretch" />

                        <Button Grid.Column="1"  x:Name="buscarClientes"  
                                
Content ="Buscar clientes (Editar o eliminar)"  
Click="BuscarClientes_Click"
Style ="{ StaticResource AccentButtonStyle }"  
HorizontalAlignment ="Stretch" />

                    </Grid >
                    

                </StackPanel >

                    <TextBox x:Name="Nombre" 
                     Header ="Nombre del cliente *" 
                     PlaceholderText ="Ej. Nelson Orlando Rodriguez"/>

                    <TextBox x:Name="Telefono" 
                       Header ="Teléfono *" 
                       PlaceholderText ="Ej. 81 1234 5678" 
                       />

                <DatePicker x:Name="FechaNacimiento" 
                        Header ="Fecha de nacimiento *" 
                                />

                <TextBox x:Name="Email"
                     Header ="Introduzca el correo electrónico"
                     PlaceholderText ="emilio@gmail.com"/>











                <TextBlock x:Name="StatusTextBlock"></TextBlock >
                    
                    

                    <Button x:Name="Submit"  
                            Content ="Registrar datos"  
                           Click="Guardar_Click"
                            Style ="{ StaticResource AccentButtonStyle }"  
                            HorizontalAlignment ="Stretch" />



                </StackPanel >
            </ScrollViewer >
        </Grid >

    
</Page>
