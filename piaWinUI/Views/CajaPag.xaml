<!-- CajaPag.xaml -->

<Page
    x:Class="piaWinUI.CajaPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20"
          RowDefinitions="Auto,Auto,*,Auto,*">

        <!-- Estado -->
        <StackPanel Orientation="Horizontal"
                    Spacing="20">

            <TextBlock x:Name="txtEstado"
                       Text="Caja cerrada"/>

            <TextBlock x:Name="txtSaldo"
                       Text="Saldo: $0"/>

            <Button Content="Abrir Caja"
                    Click="AbrirCaja_Click"/>

            <Button Content="Cerrar Caja"
                    Click="CerrarCaja_Click"/>

        </StackPanel>

        <!-- Registro -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    Margin="0,10">

            <ComboBox x:Name="cmbTipo"
                      Width="120">

                <ComboBoxItem Content="Ingreso"/>
                <ComboBoxItem Content="Egreso"/>

            </ComboBox>

            <TextBox x:Name="txtConcepto"
                     Width="200"
                     PlaceholderText="Concepto"/>

            <TextBox x:Name="txtMonto"
                     Width="120"
                     PlaceholderText="Monto"/>

            <Button Content="Registrar"
                    Click="RegistrarMovimiento_Click"/>

        </StackPanel>

        <!-- Movimientos -->
        <ListView x:Name="gridMovimientos"
                  Grid.Row="2">

            <ListView.ItemTemplate>
                <DataTemplate>

                    <Grid ColumnDefinitions="180,120,220,120,120,120">

                        <TextBlock Grid.Column="0"
                                   Text="{Binding Fecha}"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding Tipo}"/>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding Concepto}"/>

                        <TextBlock Grid.Column="3"
                                   Text="{Binding Monto}"/>

                        <TextBlock Grid.Column="4"
                                   Text="{Binding Origen}"/>

                        <TextBlock Grid.Column="5"
                                   Text="{Binding EsAutomatico}"/>

                    </Grid>

                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

        <!-- Corte -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Spacing="20"
                    Margin="0,10">

            <TextBlock x:Name="txtIngresos"
                       Text="Ingresos: $0"/>

            <TextBlock x:Name="txtEgresos"
                       Text="Egresos: $0"/>

            <TextBox x:Name="txtConteo"
                     Width="120"
                     PlaceholderText="Conteo real"/>

            <Button Content="Corte"
                    Click="CalcularCorte_Click"/>

            <Button Content="Guardar Corte"
                    Click="GuardarCorte_Click"/>

        </StackPanel>

        <!-- Historial -->
        <ListView x:Name="gridCortes"
                  Grid.Row="4">

            <ListView.ItemTemplate>
                <DataTemplate>

                    <Grid ColumnDefinitions="180,120,120,120">

                        <TextBlock Grid.Column="0"
                                   Text="{Binding Fecha}"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding Esperado}"/>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding Contado}"/>

                        <TextBlock Grid.Column="3"
                                   Text="{Binding Diferencia}"/>

                    </Grid>

                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

    </Grid>

</Page>