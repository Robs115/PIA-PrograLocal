<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="piaWinUI.Views.VentasPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    
    >

    <Grid Padding="20" RowSpacing="15">

        <!-- 🔹 Filas -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <TextBlock Text="Pantalla de ventas"
               Style="{StaticResource TitleTextBlockStyle}"
               Grid.Row="0"/>

        
        <NumberBox x:Name="CodigoBox"
               PlaceholderText="Código de barras Ej: 1234567890"
               Grid.Row="1"/>

        <!--Mas o menos la tabla esta ya preparada, solo falta hacer el binding con la lista de productos y que se actualice cada vez que se agregue un producto nuevo, o se cambie la cantidad de uno existente-->
        <!--La catnidad tendria que aumentar si escaneas un producto nuevo, tambien tendria que ser una entrada para cambiarlo manualmente-->
        <!--Despues de que se de click a finalizar venta que pida el numero del cliente (si es que tiene) y por ultimo, si es en tarjete o no-->
        <!--No he agregado el campo de metodo de pago a la interfaz, ni al modelo-->
        <ListView x:Name="ProductosList"
              Grid.Row="2">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Producto -->
                        <TextBlock Text="{Binding Nombre}"
                               Grid.Column="0"
                               VerticalAlignment="Center"/>

                        <!-- Cantidad editable -->
                        <NumberBox Value="{Binding Cantidad, Mode=TwoWay}"
                               Width="80"
                               Grid.Column="1"/>

                        <!-- Precio unitario -->
                        <TextBlock Text="{Binding Precio}"
                               Grid.Column="2"
                               VerticalAlignment="Center"/>

                        <!-- Subtotal -->
                        <TextBlock Text="{Binding Subtotal}"
                               Grid.Column="3"
                               VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

        
        <Grid Grid.Row="3" ColumnSpacing="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                Content="Buscar producto"
                Style="{StaticResource AccentButtonStyle}"
                Click="BuscarProducto_Click"/>

            <Button Grid.Column="1"
                Content="Finalizar venta"
                Style="{StaticResource AccentButtonStyle}"
                Click="GuardarVenta_Click"/>
        </Grid>

    </Grid>
</Page>