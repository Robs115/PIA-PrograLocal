<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="piaWinUI.Views.VentasPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">

    <Grid Padding="20" RowSpacing="15">

        <!-- Filas -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- Headers -->
            <RowDefinition Height="*"/>
            <!-- Lista -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Pantalla de ventas"
               Style="{StaticResource TitleTextBlockStyle}"
               Grid.Row="0"/>

        <!-- Código -->
        <TextBox x:Name="CodigoBox"
             PlaceholderText="Código de barras Ej: 1234567890"
             Grid.Row="1"
             KeyDown="obtenerproducto_keydown"/>

        <!-- 🔹 HEADERS -->
        <Grid Grid.Row="2" ColumnSpacing="10" Margin="0,10,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Producto" FontWeight="Bold" Grid.Column="0"/>
            <TextBlock Text="Cantidad" FontWeight="Bold" Grid.Column="1"/>
            <TextBlock Text="Precio" FontWeight="Bold" Grid.Column="2"/>
            <TextBlock Text="Subtotal" FontWeight="Bold" Grid.Column="3"/>
        </Grid>

        <!-- 🔹 LISTA -->
        <ListView x:Name="ProductosList"
              Grid.Row="3">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="10" Padding="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Producto -->
                        <TextBlock Text="{Binding NombreProducto}"
                               Grid.Column="0"
                               VerticalAlignment="Center"/>

                        <!-- Cantidad -->
                        <NumberBox Value="{Binding Cantidad, Mode=TwoWay}"
                               Width="80"
                               Grid.Column="1"/>

                        <!-- Precio -->
                        <TextBlock Text="{Binding PrecioUnitario}"
                               Grid.Column="2"
                               VerticalAlignment="Center"/>

                        <!-- Subtotal -->
                        <TextBlock Text="{Binding Subtotal}"
                               Grid.Column="3"
                               VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

        <!-- Botones -->
        <Grid Grid.Row="4" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                Content="Buscar producto"
                Style="{StaticResource AccentButtonStyle}"
                Click="BuscarProducto_Click"/>

            <Button Grid.Column="1"
                Content="Finalizar venta"
                Style="{StaticResource AccentButtonStyle}"
                Click="GuardarVenta_Click"/>
        </Grid>

    </Grid>
</Page>