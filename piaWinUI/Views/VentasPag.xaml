<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="piaWinUI.Views.VentasPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:piaWinUI.Converters"
    Background="#0F172A">

    <Page.Resources>
        <converters:InverseBoolToVisibilityConverter
            x:Key="InverseBoolToVisibilityConverter"/>
        
        
    </Page.Resources>

    <Grid Padding="24"
          RowSpacing="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <RelativePanel Grid.Row="0">

            <StackPanel x:Name="TitleGroup"
                        Orientation="Horizontal"
                        Spacing="8"
                        RelativePanel.AlignLeftWithPanel="True"
                        RelativePanel.AlignVerticalCenterWithPanel="True">

                <Image x:Name="ImagenProducto"
                       Source="https://static.vecteezy.com/system/resources/previews/015/664/900/non_2x/marketing-sales-icon-outline-style-vector.jpg"
                       Stretch="Uniform"
                       MaxWidth="50"
                       MaxHeight="50"/>

                <TextBlock Text="Ventas"
                           FontSize="32"
                           FontWeight="Bold"
                           x:Name="TitleText"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal" 
                        Spacing="10" 
                        RelativePanel.AlignRightWithPanel="True" 
                        RelativePanel.AlignVerticalCenterWith="TitleGroup">

                <Button x:Name="BtnCaja" Click="BtnCaja_Click" Background="#E0E0E0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon x:Name="IconoCaja" Glyph="&#xE8C7;"/>
                        <TextBlock x:Name="TxtCaja" Text="Abrir Caja" FontWeight="Bold"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnVentasRecientes"
                        Click="HistorialVentas_Click">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <FontIcon Glyph="&#xE81C;"/>
                        <TextBlock Text="Ventas Recientes"/>
                    </StackPanel>
                </Button>

            </StackPanel>

        </RelativePanel>

        <Grid Grid.Row="1"
              ColumnSpacing="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="500"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="15">

                <Grid ColumnSpacing="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="BuscarProductoBox"
                             PlaceholderText="Busqueda por nombre"
                             Grid.Column="0"
                             VerticalAlignment="Center"
                             TextChanged="BuscarProductoBox_TextChanged"
                             MaxLength="50"
                             BeforeTextChanging="BuscadorNombre_BeforeTextChanging"/>

                    <TextBox x:Name="CodigoBox"
                             PlaceholderText="Introduce codigo de barras: Ej: 121413188"
                             Grid.Column="1"
                             VerticalAlignment="Center"
                             KeyDown="obtenerproducto_keydown"
                             MaxLength="9"
                             BeforeTextChanging="BuscadorCodigo_BeforeTextChanging"/>

                    <Button x:Name="BtnEscanear"
                            Click="EscanearButton_Click" 
                            Style="{StaticResource AccentButtonStyle}"
                            Grid.Column="2"
                            VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">

                            <TextBlock Text="←Click para escanear."/>

                        </StackPanel>

                    </Button>

                </Grid>

                <GridView x:Name="ResultadosProductosList"
                          SelectionMode="None"
                          Height="680"
                          IsItemClickEnabled="True">

                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>

                    <GridView.ItemTemplate>

                        <DataTemplate>

                            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12"
                                    Width="150"
                                    Height="200"
                                    Margin="6">

                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Spacing="8">

                                    <Border Width="95"
                                            Height="95"
                                            CornerRadius="10"
                                            BorderThickness="1"
                                            BorderBrush="#404040"
                                            Background="#1F1F1F">

                                        <Grid>

                                            <Image Source="{Binding ImagenCompleta, TargetNullValue=''}"
                                               Stretch="UniformToFill"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                        </Grid>

                                    </Border>

                                    <TextBlock Text="{Binding Nombre}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxLines="2"/>

                                    <Border Background="{ThemeResource SystemAccentColorLight3}"
                                            CornerRadius="8"
                                            Padding="8,4">

                                        <TextBlock HorizontalAlignment="Center"
                                                   FontWeight="Bold">

                                            <Run Text="$"/>

                                            <Run Text="{Binding PrecioVenta}"/>

                                        </TextBlock>

                                    </Border>

                                </StackPanel>

                            </Border>

                        </DataTemplate>

                    </GridView.ItemTemplate>

                </GridView>

            </StackPanel>

            <Border Grid.Column="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <controls:DataGrid Grid.Row="0"
                                       x:Name="ProductosList"
                                       AutoGenerateColumns="False"
                                       IsReadOnly="True"
                                       GridLinesVisibility="Vertical"
                                       HeadersVisibility="Column"
                                       CanUserResizeColumns="False"
                                       CanUserReorderColumns="False"
                                       Margin="10"
                                       SelectionMode="Single"
                                       RowHeight="50">

                        <controls:DataGrid.Columns>

                            <controls:DataGridTemplateColumn Header="Producto"
                                                             Width="2*">

                                <controls:DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <TextBlock Text="{Binding NombreProducto}"
           VerticalAlignment="Center"
           HorizontalAlignment="Center" 
           TextTrimming="CharacterEllipsis"
           ToolTipService.ToolTip="{Binding NombreProducto}"/>

                                    </DataTemplate>

                                </controls:DataGridTemplateColumn.CellTemplate>

                            </controls:DataGridTemplateColumn>

                            <controls:DataGridTemplateColumn Header="Cantidad"
                                                             Width="2*">

                                <controls:DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <NumberBox Value="{Binding Cantidad, Mode=TwoWay}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Width="80"
                                                   Minimum="1"
                                                   Maximum="999"
                                                   AcceptsExpression="False"
                                                   PlaceholderText="0"
                                                   PreviewKeyDown="NumberBoxCantidad_PreviewKeyDown"
                                                   Loaded="NumberBoxCantidad_Loaded"
                                                   ValidationMode="InvalidInputOverwritten"
                                                   LostFocus="NumberBoxCantidad_Loaded">

                                        </NumberBox>

                                    </DataTemplate>

                                </controls:DataGridTemplateColumn.CellTemplate>

                            </controls:DataGridTemplateColumn>

                            <controls:DataGridTemplateColumn Header="Costo Unitario"
                                                             Width="3*">

                                <controls:DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">

                                            <Run Text="$"/>

                                            <Run Text="{Binding PrecioUnitario}"/>

                                        </TextBlock>

                                    </DataTemplate>

                                </controls:DataGridTemplateColumn.CellTemplate>

                            </controls:DataGridTemplateColumn>

                            <controls:DataGridTemplateColumn Header="Subtotal"
                                                             Width="2*">

                                <controls:DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">

                                            <Run Text="$"/>

                                            <Run Text="{Binding Subtotal}"/>

                                        </TextBlock>

                                    </DataTemplate>

                                </controls:DataGridTemplateColumn.CellTemplate>

                            </controls:DataGridTemplateColumn>

                            <controls:DataGridTemplateColumn Header="Acción"
                                                             Width="2*">

                                <controls:DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <Button Click="EliminarProducto_Click"
                                                Tag="{Binding}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">

                                            <SymbolIcon Symbol="Delete"/>

                                        </Button>

                                    </DataTemplate>

                                </controls:DataGridTemplateColumn.CellTemplate>

                            </controls:DataGridTemplateColumn>

                        </controls:DataGrid.Columns>

                    </controls:DataGrid>

                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,20">

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right">

                            <TextBlock Text="TOTAL: "
                                       FontSize="28"
                                       FontWeight="Bold"
                                       VerticalAlignment="Bottom"/>

                            <TextBlock x:Name="TotalText"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource SystemAccentColor}"/>

                        </StackPanel>

                    </StackPanel>

                    <Grid Grid.Row="2"
                          ColumnSpacing="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Height="90"
                                HorizontalAlignment="Stretch"
                                Background="{ThemeResource SystemAccentColor}"
                                Foreground="White"
                                Click="BotonEfectivo_Click">

                            <StackPanel Spacing="8">

                                <PathIcon Data="M 1,5 L 23,5 L 23,19 L 1,19 Z M 12,8 A 4,4 0 1 0 12,16 A 4,4 0 1 0 12,8 Z" HorizontalAlignment="Center"/>


                                <TextBlock Text="EFECTIVO"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button Grid.Column="1"
                                Height="90"
                                HorizontalAlignment="Stretch"
                                Click="BotonTarjeta_Click"
                                Background="{ThemeResource SystemAccentColor}"
                                Foreground="White">
                            <StackPanel Spacing="8">
                                
                                <FontIcon Glyph="&#xE8C7;"
                                          FontSize="24"
                                          HorizontalAlignment="Center"/>


                                <TextBlock Text="TARJETA"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                    </Grid>

                </Grid>

            </Border>

        </Grid>

        <TextBlock Grid.Row="2"
                   x:Name="CajeroHoraTextBlock"
                   Foreground="Gray"
                   FontSize="12"
                   Margin="0,12,0,0"/>

    </Grid>

</Page>