<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="piaWinUI.Views.VentasPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
     
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Encabezado -->
            <RowDefinition Height="*"/>
            <!-- Contenido -->
            <RowDefinition Height="Auto"/>
            <!-- Barra de estado inferior -->
        </Grid.RowDefinitions>

        <!-- Encabezado: Título y Botón Historial -->
        <!-- Ajuste: RelativePanel ahora alinea el icono y el texto juntos a la izquierda, 
             y el botón "Ventas Recientes" a la derecha -->
        <RelativePanel Grid.Row="0">
            <StackPanel x:Name="TitleGroup" Orientation="Horizontal" Spacing="8" RelativePanel.AlignLeftWithPanel="True" RelativePanel.AlignVerticalCenterWithPanel="True">
                <Image x:Name="ImagenProducto"
       Source="https://static.vecteezy.com/system/resources/previews/015/664/900/non_2x/marketing-sales-icon-outline-style-vector.jpg"

       Stretch="Uniform"
       MaxWidth="50"
       MaxHeight="50"/>
                <TextBlock Text="Ventas" FontSize="32" FontWeight="Bold" x:Name="TitleText" HorizontalAlignment="Center"/>
            </StackPanel>

            <Button x:Name="BtnVentasRecientes"
        RelativePanel.AlignRightWithPanel="True"
        RelativePanel.AlignVerticalCenterWith="TitleGroup"
                    Click="HistorialVentas_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <!-- Icono alternativo usando Segoe MDL2 Assets (Reloj de historial) -->
                    <FontIcon Glyph="&#xE81C;" />
                    <TextBlock Text="Ventas Recientes"/>
                </StackPanel>
            </Button>
        </RelativePanel>

        <!-- Contenido Principal -->
        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Catálogo -->
                <ColumnDefinition Width="600"/>
                <!-- Carrito/Ticket -->
            </Grid.ColumnDefinitions>

            <!-- SECCIÓN IZQUIERDA: CATÁLOGO -->
            <StackPanel Spacing="15">
                <!-- Ajuste: Usamos un Grid con columnas para organizar los nuevos botones 
                     y el AutoSuggestBox de forma uniforme -->
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <!-- AutoSuggestBox ocupa el resto -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Botones ocupan su contenido -->
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="BuscarProductoBox"  PlaceholderText="Busqueda por nombre" Grid.Column="0" VerticalAlignment="Center" TextChanged="BuscarProductoBox_TextChanged" MaxLength="50" BeforeTextChanging="BuscadorNombre_BeforeTextChanging"/>
                    <TextBox x:Name="CodigoBox" PlaceholderText="Introduce codigo de barras: Ej: 1234567899000" Grid.Column="1" VerticalAlignment="Center" KeyDown="obtenerproducto_keydown" MaxLength="42" BeforeTextChanging="BuscadorCodigo_BeforeTextChanging"/>

                    <!-- Ajuste: Agregué iconos a los botones para alinearlos visualmente con 
                         el resto de la interfaz (según la estética de image_4.png) -->
                    <Button x:Name="BtnEscanear" Style="{StaticResource AccentButtonStyle}" Grid.Column="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            
                            <!-- Icono de Código de Barras -->
                            <TextBlock Text="←Click para escanear."/>
                        </StackPanel>
                    </Button>

                   
                </Grid>
                <GridView x:Name="ResultadosProductosList" SelectionMode="None" Height="400">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    CornerRadius="8" Padding="12" Width="140" Height="160" Margin="4">
                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <!-- Imagen del producto (placeholder de un icono) -->
                                    <!--<Image Source="ms-appx:///Assets/placeholder.png" Height="80" Stretch="UniformToFill"/> -->
                                    <SymbolIcon Symbol="Shop" Height="80" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <!-- Nombre del producto -->
                                    <TextBlock Text="{Binding Nombre}" 
                               FontWeight="SemiBold" 
                               HorizontalAlignment="Center" 
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                                    <!--Precio del producto run no afecta la manera en la que hace binding segun chat -->
                                    <TextBlock HorizontalAlignment="Center" >
<Run Text="$"/>
<Run Text="{Binding PrecioVenta}"
Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                    </TextBlock>
                                    
                                    
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
              
            </StackPanel>

            <!-- SECCIÓN DERECHA: TICKET -->
            <Border Grid.Column="1" 
                    Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <!-- Lista de artículos -->
                        <RowDefinition Height="Auto"/>
                        <!-- Totales -->
                        <RowDefinition Height="Auto"/>
                        <!-- Botones Cobro -->
                    </Grid.RowDefinitions>


                    <controls:DataGrid Grid.Row="0"
             x:Name="ProductosList"
        
        AutoGenerateColumns="False"
                IsReadOnly="True"
                GridLinesVisibility="Vertical"
                HeadersVisibility="Column"
                
                Margin="10"
                SelectionMode="Single"
                RowHeight="50">

                    <controls:DataGrid.Columns>
                        <!--Producto-->
                        <controls:DataGridTemplateColumn Header="Producto"
                                                         Width="2*">
                            <controls:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                        <TextBlock Text="{Binding NombreProducto}"
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>        

                                    </DataTemplate>
                            </controls:DataGridTemplateColumn.CellTemplate>
                        </controls:DataGridTemplateColumn>
                            <!--Cantidad-->
                            <controls:DataGridTemplateColumn Header="Cantidad"
                                 Width="2*">
                                <controls:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <NumberBox Value="{Binding Cantidad, Mode=TwoWay}"
                                                   VerticalAlignment="Center"
           HorizontalAlignment="Center"
             Width="80"
             Grid.Column="1"
             AcceptsExpression="False"

PlaceholderText="0"
                                        Maximum="999"
                 Minimum="1"/>

                                    </DataTemplate>
                                </controls:DataGridTemplateColumn.CellTemplate>
                            </controls:DataGridTemplateColumn>

                            <!--Precio Unitario-->
                            <controls:DataGridTemplateColumn Header="Costo Unitario"
                                 Width="2*">
                            <controls:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="2">
    <Run Text="$"/>
    <Run Text="{Binding PrecioUnitario}"/>
                                        </TextBlock>

                                    </DataTemplate>
                            </controls:DataGridTemplateColumn.CellTemplate>
                            </controls:DataGridTemplateColumn>

                            <!--Subtotal -->
                            <controls:DataGridTemplateColumn Header="Subtotal"
                                 Width="2*">
                                <controls:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="3">
<Run Text="$"/>
<Run Text="{Binding Subtotal}"/>
                                        </TextBlock>

                                    </DataTemplate>
                                </controls:DataGridTemplateColumn.CellTemplate>
                            </controls:DataGridTemplateColumn>
                        <!--Eliminar-->
                            <controls:DataGridTemplateColumn Header="Acción"
                                                         Width="2*">

                            <controls:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <StackPanel Orientation="Horizontal" Spacing="8">



                                            <Button Grid.Column="4"
Click="EliminarProducto_Click"
Tag="{Binding}">
                                                <SymbolIcon Symbol="Delete"/>
                                            </Button>

                                        </StackPanel>

                                </DataTemplate>
                            </controls:DataGridTemplateColumn.CellTemplate>
                        </controls:DataGridTemplateColumn>


                    </controls:DataGrid.Columns>


                    </controls:DataGrid>

             

                    <StackPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="TOTAL: " FontSize="28" FontWeight="Bold" VerticalAlignment="Bottom"/>
                            <TextBlock x:Name="TotalText" FontSize="36" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" />
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Row="2" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Height="80" HorizontalAlignment="Stretch" 
                                Background="{ThemeResource SystemAccentColor}" Foreground="White" Click="GuardarVenta_Click">
                            <StackPanel Spacing="8">
                                <FontIcon Glyph="&#xE8C7;"/>
                                <!-- Icono de Dinero -->
                                <TextBlock Text="EFECTIVO" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1" Height="80" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="8">
                                <FontIcon Glyph="&#xE7E1;"/>
                                <!-- Icono de Tarjeta -->
                                <TextBlock Text="TARJETA" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        <!-- Panel de Historial de Ventas -->
       
        <!-- Footer -->
        <TextBlock Grid.Row="2" x:Name="CajeroHoraTextBlock" Foreground="Gray" FontSize="12" Margin="0,12,0,0"/>
    </Grid>
</Page>
