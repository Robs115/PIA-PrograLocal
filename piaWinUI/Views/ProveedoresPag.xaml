<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="piaWinUI.Views.ProveedoresPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:piaWinUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d"
    Background="#0F172A">

    <Page.Resources>
        <!-- This targets the specific corner radius of the content area -->
        <CornerRadius x:Key="NavigationViewContentGridCornerRadius">0</CornerRadius>
    </Page.Resources>


    <Grid Padding="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <Border Grid.Column="0"
             Background="#111827"
             CornerRadius="12"
             Padding="20"
             BorderBrush="#334155"
             BorderThickness="1">

            <StackPanel Spacing="15">

                <SymbolIcon Symbol ="AddFriend"
                    Foreground="#60A5FA"/>

                <TextBlock Text ="Crear proveedor"  
                Style ="{StaticResource TitleTextBlockStyle }" 
                HorizontalAlignment ="Center"
                Foreground="#E2E8F0"/>

                <TextBlock Text ="Introduce los datos"  
                Style ="{StaticResource CaptionTextBlockStyle }"  
                Foreground ="#94A3B8"
                HorizontalAlignment ="Center" />


                <TextBox x:Name="Nombre" 
             Header ="Nombre del proveedor *" 
             PlaceholderText ="Ej. Nelson Orlando Rodriguez"
             MaxLength="50"
             BeforeTextChanging="Nombre_BeforeTextChanging"
             Background="#0F172A"
             Foreground="#F8FAFC"
             BorderBrush="#334155"/>

                <TextBox x:Name="Telefono" 
               Header ="Teléfono *" 
               PlaceholderText ="Ej. 81 1234 5678" 
               MaxLength="10"
               BeforeTextChanging="Telefono_BeforeTextChanging"
               Background="#0F172A"
               Foreground="#F8FAFC"
               BorderBrush="#334155"/>


                <TextBox x:Name="Email"
             Header ="Introduzca el correo electrónico*"
             PlaceholderText ="emilio@gmail.com"
             MaxLength="50"
             BeforeTextChanging="Email_BeforeTextChanging"
             Background="#0F172A"
             Foreground="#F8FAFC"
             BorderBrush="#334155"/>

                <TextBlock x:Name="toast"
                   Foreground="#E2E8F0"/>

                <Button x:Name="Submit"  
                Content ="Registrar datos"  
                Click="Guardar_Click"
                Style ="{ StaticResource AccentButtonStyle }"  
                HorizontalAlignment ="Stretch"
                Background="#2563EB"
                Foreground="White"/>

            </StackPanel>
        </Border>


        <StackPanel Grid.Column="1" Margin="20,0,0,0" Spacing="10">

            <TextBlock Text ="Historial de proveedores"  
        Style ="{StaticResource TitleTextBlockStyle }" 
        HorizontalAlignment ="Center" />


            <TextBox x:Name="buscador"
                 PlaceholderText="Introduce el nombre....."
                 TextChanged="Buscador_TextChanged"
                     BeforeTextChanging="Buscador_BeforeTextChanging"
                     MaxLength="50"/>





            <controls:DataGrid
    x:Name="DataGridProveedores"
    AutoGenerateColumns="False"
    IsReadOnly="True"
    GridLinesVisibility="Vertical"
    HeadersVisibility="Column"
    CanUserResizeColumns="False"
    CanUserReorderColumns="False"
    Margin="10"
    SelectionMode="Single"
    RowHeight="50"
    CellEditEnding="DataGridProveedores_CellEditEnding">

                <controls:DataGrid.Columns>

                    <!-- Nombre -->
                    <controls:DataGridTemplateColumn Header="Nombre" Width="2*">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Nombre}"
                               TextDecorations="Underline"
                               VerticalAlignment="Center"
                               TextAlignment="Center"/>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>

                        <controls:DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Nombre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellEditingTemplate>
                    </controls:DataGridTemplateColumn>

                    <!-- Teléfono -->
                    <controls:DataGridTextColumn Header="Teléfono"
                                     Width="2*"
                                     Binding="{Binding Telefono, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 />

                    <!-- Email -->
                    <controls:DataGridTextColumn Header="Email"
                                     Width="2*"
                                     Binding="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <!-- Acciones -->
                    <controls:DataGridTemplateColumn Header="Acciones" Width="2*">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8"  HorizontalAlignment="Center"
 VerticalAlignment="Center">
                                    <Button Content="Editar"
                                Click="EditarProveedor_Click"
                                Tag="{Binding}" 
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                    <Button Content="Eliminar"
                                Click="Eliminar_Click"
                                Tag="{Binding}" 
                                            HorizontalAlignment="Center"
VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                </controls:DataGrid.Columns>
            </controls:DataGrid>

            <StackPanel Orientation="Horizontal"
        HorizontalAlignment="Right"
        VerticalAlignment="Bottom"
        Margin="10">

                    
                </StackPanel>

        </StackPanel>
        
        

    </Grid>


</Page>
