<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="piaWinUI.Views.EditProductoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:piaWinUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="14">

                <StackPanel HorizontalAlignment="Center"
                        Margin="0,0,0,12"
                        Spacing="8" Width="800">

                    <SymbolIcon Symbol="Edit" />

                    <TextBlock Text="Editar producto"
                           Style="{StaticResource TitleTextBlockStyle}"
                           HorizontalAlignment="Center" />

                    <TextBlock Text="Modifica los datos del producto"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />

                    <!-- Nombre -->
                    <TextBox x:Name="txtNombre"
                         Header="Nombre"
                         PlaceholderText="Ej. Coca Cola 600ml"
                         MaxLength="30"/>

                    <!-- Descripción -->
                    <TextBox x:Name="txtDescripcion"
                         Header="Descripción"
                         PlaceholderText="Descripción del producto"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MaxLength="100"/>

                    <!-- Categoría -->
                    <ComboBox x:Name="cmbCategoria"
                          Header="Categoría"
                          PlaceholderText="Selecciona una categoría">

                        <ComboBoxItem Content="Bebidas"/>
                        <ComboBoxItem Content="Comida"/>
                        <ComboBoxItem Content="Lácteos"/>
                        <ComboBoxItem Content="Panadería"/>
                        <ComboBoxItem Content="Congelados"/>
                        <ComboBoxItem Content="Snacks"/>
                        <ComboBoxItem Content="Limpieza"/>
                        <ComboBoxItem Content="Higiene personal"/>
                        <ComboBoxItem Content="Electrónica"/>
                        <ComboBoxItem Content="Otros"/>

                    </ComboBox>

                    <!-- Precio compra -->
                    <TextBox x:Name="txtPrecioCompra"
                         Header="Precio de compra"
                         PlaceholderText="0.00"
                         InputScope="Number"
                         MaxLength="9"/>

                    <!-- Precio venta -->
                    <TextBox x:Name="txtPrecioVenta"
                         Header="Precio de venta"
                         PlaceholderText="0.00"
                         InputScope="Number"
                         MaxLength="9"/>

                    <!-- Stock -->
                    <TextBox x:Name="txtStock"
                         Header="Stock"
                         PlaceholderText="0"
                         InputScope="Number"
                         MaxLength="9"/>

                    <!-- Proveedor -->
                    <ComboBox x:Name="cmbProveedor"
                          Header="Proveedor"
                          PlaceholderText="Selecciona un proveedor"
                          DisplayMemberPath="Nombre"
                          SelectedValuePath="IdProveedor"/>

                    <!-- Status -->
                    <TextBlock x:Name="StatusTextBlock"
                           TextWrapping="Wrap"/>

                    <!-- Save button -->
                    <Button x:Name="btnGuardar"
                        Content="Guardar cambios"
                        Click="Save_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch"/>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
    
</Page>
