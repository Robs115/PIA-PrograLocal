<Page
    x:Class="piaWinUI.Views.ReporteVentasPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">

    <Grid Padding="20">

        <StackPanel Spacing="20">

            <!-- HEADER -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Stretch">

                <Button Content="← Volver"
                        Click="Volver_Click"/>

                <TextBlock Text="Reporte de Ventas"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- TABLA -->
            <Border Background="#2C2C2C"
                    CornerRadius="12"
                    Padding="15">

                <controls:DataGrid
                    x:Name="VentasGrid"
                    ItemsSource="{Binding Ventas}"
                    AutoGenerateColumns="False"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    RowHeight="50"
                    CanUserResizeColumns="False">

                    <controls:DataGrid.Columns>

                        <controls:DataGridTextColumn
                            Header="ID"
                            Binding="{Binding Id}"
                            Width="80"/>

                        <controls:DataGridTextColumn
                            Header="Usuario"
                            Binding="{Binding UserName}"
                            Width="200"/>

                        <controls:DataGridTextColumn
                            Header="Fecha"
                            Binding="{Binding Fecha}"
                            Width="200"/>

                        <controls:DataGridTextColumn
                            Header="Total"
                            Binding="{Binding Total}"
                            Width="150"/>

                        <!-- BOTON -->
                        <controls:DataGridTemplateColumn
                            Header="Acciones"
                            Width="180">

                            <controls:DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <Button Content="Ver detalle"
                                            Tag="{Binding}"
                                            Click="VerDetalle_Click"/>

                                </DataTemplate>
                            </controls:DataGridTemplateColumn.CellTemplate>

                        </controls:DataGridTemplateColumn>

                    </controls:DataGrid.Columns>

                </controls:DataGrid>

            </Border>

        </StackPanel>

    </Grid>

</Page>