<?xml version="1.0" encoding="utf-8"?>

<Page
    x:Class="piaWinUI.Views.ProductosPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14">

                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,12" Spacing="8" Width="800">
                    <SymbolIcon Symbol="Tag" />
                    <TextBlock Text="Crear producto"  
                       Style="{StaticResource TitleTextBlockStyle}" 
                       HorizontalAlignment="Center" />
                    <TextBlock Text="Introduce los datos"  
                       Style="{StaticResource CaptionTextBlockStyle}"  
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                       HorizontalAlignment="Center" />

                    <TextBox x:Name="txtNombre"
                             Header="Nombre"
                             PlaceholderText="Ej. Coca Cola 600ml"
                             MaxLength="30"/>

                    <TextBox x:Name="txtDescripcion"
                             Header="Descripción"
                             PlaceholderText="Descripción del producto"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MaxLength="100"/>

                    <ComboBox x:Name="cmbCategoria"
                        Header="Categoría"
                        PlaceholderText="Selecciona una categoría">   

                        <ComboBoxItem Content="Bebidas"/>
                        <ComboBoxItem Content="Comida"/>
                        <ComboBoxItem Content="Lácteos"/>
                        <ComboBoxItem Content="Panadería"/>
                        <ComboBoxItem Content="Congelados"/>
                        <ComboBoxItem Content="Snacks"/>
                        <ComboBoxItem Content="Limpieza"/>
                        <ComboBoxItem Content="Higiene personal"/>
                        <ComboBoxItem Content="Electrónica"/>
                        <ComboBoxItem Content="Otros"/>

                    </ComboBox>

                    <TextBox x:Name="txtPrecioCompra"
                             Header="Precio de compra"
                             PlaceholderText="0.00"
                             InputScope="Number"
                             MaxLength="9"/>

                    <TextBox x:Name="txtPrecioVenta"
                             Header="Precio de venta"
                             PlaceholderText="0.00"
                             InputScope="Number"
                              MaxLength="9"/>

                    <TextBox x:Name="txtStock"
                             Header="Stock"
                             PlaceholderText="0"
                             InputScope="Number"
                             MaxLength="9"/>

                    <ComboBox x:Name="cmbProveedor"
                              Header="Proveedor"
                              PlaceholderText="Selecciona un proveedor"
                              DisplayMemberPath="Nombre"/>

                    <TextBlock x:Name="StatusTextBlock"
                               TextWrapping="Wrap"
                               MaxWidth="800"
                               Margin="0 20 0 20"/>

                    <Button x:Name="Submit"
                            IsEnabled="False"
                            Content="Registrar datos"  
                            Click="Validator"
                            Style="{StaticResource AccentButtonStyle}"  
                            HorizontalAlignment="Stretch"/>
                </StackPanel>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="reportesProductos"  
                            Content="Reportes de productos"  
                            Style="{StaticResource AccentButtonStyle}"  
                            HorizontalAlignment="Stretch" 
                            Click="MoveTo"/>

                    <Button Grid.Column="2" x:Name="InventarioProductos"  
                            Content="Inventario de productos"
                            Click="MoveTo"
                            Style="{StaticResource AccentButtonStyle}"  
                            HorizontalAlignment="Stretch" />
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</Page>