<Page
    x:Class="piaWinUI.Views.ProductosPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    Background="#0F172A">

    <Grid Padding="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Grid Grid.Row="0" Margin="0,0,0,15">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Productos"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#E2E8F0"/>

                <TextBlock Text="Inventario"
                           Opacity="0.7"
                           Foreground="#CBD5E1"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">

                <Button Content="+ Categoría"
                        Click="OpenAddCategoryDialog"
                        Padding="14,8"
                        CornerRadius="10"
                        Background="#1E293B"
                        Foreground="White"
                        BorderBrush="#334155"/>

                <Button Content="+ Producto"
                        Click="OpenAddDialog"
                        Padding="14,8"
                        CornerRadius="10"
                        Style="{StaticResource AccentButtonStyle}"
                        FontWeight="SemiBold"
                        Background="#2563EB"
                        Foreground="White"/>
            </StackPanel>
        </Grid>

        <!-- FILTROS -->

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    Margin="0,0,0,15">

            <TextBox x:Name="SearchBox"
                     Width="260"
                     PlaceholderText="Buscar producto..."
                     TextChanged="SearchBox_TextChanged"
                     BeforeTextChanging="SearchBox_BeforeTextChanging"
                     MaxLength="50"
                     Background="#111827"
                     Foreground="#E2E8F0"
                     BorderBrush="#334155"/>

            <ComboBox x:Name="CategoriaBox"
                      Width="180"
                      SelectionChanged="CategoriaBox_SelectionChanged"
                      Background="#111827"
                      Foreground="#E2E8F0"
                      BorderBrush="#334155"/>

            <Button Content="Limpiar"
                    Click="Limpiar_Click"
                    Background="#1E293B"
                    Foreground="White"
                    BorderBrush="#334155"/>
        </StackPanel>

        <!-- GRID -->

        <Border Grid.Row="2"
                CornerRadius="12"
                Padding="10"
                Background="#111827"
                BorderBrush="#1E293B"
                BorderThickness="1">

            <controls:DataGrid
                x:Name="ProductosGrid"
                AutoGenerateColumns="False"
                HeadersVisibility="Column"
                IsReadOnly="True"
                SelectionMode="Single"
                GridLinesVisibility="Horizontal"
                CanUserResizeColumns="False"
                CanUserReorderColumns="False"
                Background="#111827"
                Foreground="#E2E8F0"
                BorderBrush="#1E293B"
                RowBackground="#111827"
                AlternatingRowBackground="#172033"
                HorizontalGridLinesBrush="#1E293B"
                VerticalGridLinesBrush="#1E293B"
                >

                <controls:DataGrid.Columns>

                    <controls:DataGridTextColumn
                        Header="Nombre"
                        Binding="{Binding Nombre}"
                        Width="2*"/>

                    <controls:DataGridTextColumn
                        Header="Código"
                        Binding="{Binding CodigoBarras}"
                        Width="120"/>

                    <controls:DataGridTextColumn
                        Header="Categoría"
                        Binding="{Binding Categoria}"
                        Width="*"/>

                    <controls:DataGridTextColumn
                        Header="Compra"
                        Binding="{Binding PrecioCompra}"
                        Width="*"/>

                    <controls:DataGridTextColumn
                        Header="Venta"
                        Binding="{Binding PrecioVenta}"
                        Width="*"/>

                    <controls:DataGridTextColumn
                        Header="Stock"
                        Binding="{Binding Stock}"
                        Width="*"/>

                    <controls:DataGridTextColumn
                        Header="Proveedor"
                        Binding="{Binding IdProveedor}"
                        Width="*"/>

                    <controls:DataGridTemplateColumn
                        Header="Acciones"
                        Width="170">

                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <StackPanel Orientation="Horizontal"
                                            Spacing="8">

                                    <Button Content="Editar"
                                            Tag="{Binding}"
                                            Click="Edit_Click"
                                            Background="#2563EB"
                                            Foreground="White"/>

                                    <Button Content="Eliminar"
                                            Tag="{Binding}"
                                            Click="Delete_Click"
                                            Background="#DC2626"
                                            Foreground="White"/>
                                </StackPanel>

                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                </controls:DataGrid.Columns>

            </controls:DataGrid>

        </Border>

    </Grid>
</Page>
