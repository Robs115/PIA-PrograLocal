<Page
    x:Class="piaWinUI.Views.ProductosPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Productos"
                           FontSize="28"
                           FontWeight="Bold"/>

                <TextBlock Text="Gestión de inventario"
                           Opacity="0.6"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="10"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom">

                <Button Content="+ Agregar Categoría"
                        Click="OpenCategoriaDialog"
                        Padding="14,8"
                        CornerRadius="10"
                        Background="{ThemeResource SystemControlBackgroundAccentBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"/>

                <Button Content="＋ Agregar Producto"
                        Click="OpenAddDialog"
                        Padding="14,8"
                        CornerRadius="10"
                        Background="{ThemeResource SystemControlBackgroundAccentBrush}"
                        Foreground="White"
                        FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    Spacing="12" 
                    Margin="0,0,0,5">

            <AutoSuggestBox x:Name="SearchBox"
                            PlaceholderText="Buscar por nombre..."
                            QueryIcon="Find"
                            Width="300"
                            CornerRadius="8"
                            VerticalAlignment="Center"
                            TextChanged="OnFilterChanged"/>

            <ComboBox x:Name="ComboFiltroCategoria"
                      PlaceholderText="Categoría: Todas"
                      Width="200"
                      CornerRadius="8"
                      VerticalAlignment="Center"
                      DisplayMemberPath="Nombre"
                      SelectionChanged="OnFilterChanged"/>

            <Button Content="Limpiar Filtros" 
                    Click="LimpiarFiltros_Click"
                    VerticalAlignment="Center"
                    Padding="12,7"
                    CornerRadius="8"/>
        </StackPanel>

        <Border Grid.Row="2"
                Margin="0,15,0,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="16"
                Padding="16">

            <controls:DataGrid
                ItemsSource="{x:Bind Productos}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                HeadersVisibility="Column"
                GridLinesVisibility="Horizontal"
                SelectionMode="Single"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False">

                <controls:DataGrid.Columns>
                    <controls:DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="2*"/>
                    <controls:DataGridTextColumn Header="Categoría" Binding="{Binding Categoria}" Width="*"/>
                    <controls:DataGridTextColumn Header="Compra" Binding="{Binding PrecioCompra}" Width="*"/>
                    <controls:DataGridTextColumn Header="Venta" Binding="{Binding PrecioVenta}" Width="*"/>
                    <controls:DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="*"/>
                    <controls:DataGridTextColumn Header="Proveedor" Binding="{Binding ProveedorNombre}" Width="2*"/>

                    <controls:DataGridTemplateColumn Header="Acciones" Width="Auto">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,0">
                                    <Button Content="Editar"
                                            Click="Edit_Click"
                                            Tag="{Binding}"
                                            Padding="10,4"
                                            CornerRadius="6"
                                            Background="{ThemeResource SystemControlBackgroundAccentBrush}"
                                            Foreground="White"
                                            FontWeight="SemiBold"/>

                                    <Button Content="Eliminar"
                                            Click="Delete_Click"
                                            Tag="{Binding}"
                                            Padding="10,4"
                                            CornerRadius="6"
                                            Background="IndianRed"
                                            Foreground="White"
                                            FontWeight="SemiBold"/>
                                </StackPanel>
                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>
                </controls:DataGrid.Columns>

            </controls:DataGrid>
        </Border>

    </Grid>
</Page>