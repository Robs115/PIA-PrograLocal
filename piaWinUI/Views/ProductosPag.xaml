<?xml version="1.0" encoding="utf-8"?>

<Page
    x:Class="piaWinUI.Views.ProductosPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>

        <!-- Header -->
        <Grid ColumnDefinitions="50,*,100,100" Padding="5">
            <TextBlock Text="ID" FontWeight="Bold" Grid.Column="0"/>
            <TextBlock Text="Nombre" FontWeight="Bold" Grid.Column="1"/>
            <TextBlock Text="Precio" FontWeight="Bold" Grid.Column="2"/>
            <TextBlock Text="Stock" FontWeight="Bold" Grid.Column="3"/>
        </Grid>

        <!-- List -->
        <ListView ItemsSource="{Binding Productos}"
              SelectedItem="{Binding ProductoSeleccionado, Mode=TwoWay}">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="50,*,100,100" Padding="5">
                        <TextBlock Text="{Binding Id}" Grid.Column="0"/>
                        <TextBox Text="{Binding Nombre, Mode=TwoWay}" Grid.Column="1"/>
                        <TextBox Text="{Binding Precio, Mode=TwoWay}" Grid.Column="2"/>
                        <TextBox Text="{Binding Stock, Mode=TwoWay}" Grid.Column="3"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>
    </StackPanel>
    
</Page>