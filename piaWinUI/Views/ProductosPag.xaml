<Page
    x:Class="piaWinUI.Views.ProductosPag"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Productos"
                           FontSize="28"
                           FontWeight="Bold"/>

                <TextBlock Text="Gestión de inventario"
                           Opacity="0.6"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="＋ Agregar"
                    Click="OpenAddDialog"
                    Padding="14,8"
                    CornerRadius="10"/>
        </Grid>

        <!-- TABLA -->
        <Border Grid.Row="1"
                Margin="0,20,0,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="16"
                Padding="16">

            <controls:DataGrid
                ItemsSource="{x:Bind Productos}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                HeadersVisibility="Column"
                GridLinesVisibility="Horizontal"
                SelectionMode="Single"
                CanUserReorderColumns="False"
                CanUserResizeColumns="False">

                <controls:DataGrid.Columns>

                    <controls:DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="2*"/>
                    <controls:DataGridTextColumn Header="Categoría" Binding="{Binding Categoria}" Width="*"/>
                    <controls:DataGridTextColumn Header="Compra" Binding="{Binding PrecioCompra}" Width="*"/>
                    <controls:DataGridTextColumn Header="Venta" Binding="{Binding PrecioVenta}" Width="*"/>
                    <controls:DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="*"/>
                    <controls:DataGridTextColumn Header="Proveedor" Binding="{Binding ProveedorNombre}" Width="2*"/>

                    <!-- ACCIONES -->
                    <controls:DataGridTemplateColumn Header="Acciones" Width="*">
                        <controls:DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <StackPanel Orientation="Horizontal" Spacing="8">

                                    <!-- EDITAR -->
                                    <Button Content="Editar"
                                            Click="Edit_Click"
                                            Tag="{Binding}"
                                            Padding="10,4"
                                            CornerRadius="6"
                                            Background="{ThemeResource SystemControlBackgroundAccentBrush}"
                                            Foreground="White"
                                            FontWeight="SemiBold"/>

                                    <!-- ELIMINAR -->
                                    <Button Content="Eliminar"
                                            Click="Delete_Click"
                                            Tag="{Binding}"
                                            Padding="10,4"
                                            CornerRadius="6"
                                            Background="IndianRed"
                                            Foreground="White"
                                            FontWeight="SemiBold"/>

                                </StackPanel>

                            </DataTemplate>
                        </controls:DataGridTemplateColumn.CellTemplate>
                    </controls:DataGridTemplateColumn>

                </controls:DataGrid.Columns>

            </controls:DataGrid>

        </Border>

    </Grid>
</Page>